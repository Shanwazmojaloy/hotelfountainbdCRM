# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Multi-tenant identifier (browser-exposed; safe)
NEXT_PUBLIC_TENANT_ID=46bbc3ff-b1ef-4d54-87be-3ecd0eb635a8

# AI
GEMINI_API_KEY=your_gemini_api_key

# Automation
MAKE_WEBHOOK_URL=your_make_com_webhook_url

# Email (Brevo)
BREVO_API_KEY=your_brevo_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MojaInventry Bridge
MOJAINVENTRY_API_URL=https://api.mojainventry.com
MOJAINVENTRY_API_KEY=your_mojainventry_api_key

# Facebook Graph API (Automated Marketer agent)
# Get from: https://developers.facebook.com → Your App → Tools → Graph API Explorer
# Required permission: pages_manage_posts, pages_read_engagement
# Token type: Page Access Token (long-lived, never expires if generated correctly)
FACEBOOK_PAGE_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
