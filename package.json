{
  "name": "hotel-fountain-crm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:crm && next build",
    "vercel-build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:crm": "babel public/crm-src.jsx --config-file ./babel.crm.json --out-file public/crm-bundle.js && terser public/crm-bundle.js --compress --mangle --output public/crm-bundle.js && node scripts/bump-cache.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.56.2",
    "@tanstack/react-query-devtools": "^5.56.2",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "next": "^15.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "imapflow": "^1.0.162"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "@babel/cli": "^7.23.5",
    "@babel/preset-react": "^7.23.5",
    "terser": "^5.31.0"
  }
}
