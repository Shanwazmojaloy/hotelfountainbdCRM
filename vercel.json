{
  "version": 2,
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["sin1"],
  "rewrites": [
    { "source": "/crm.html", "destination": "/crm.html" },
    { "source": "/landing", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/agents/outreach-bot",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/agents/daily-ops",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/agents/weekly-retention",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/agents/reply-intake-poll",
      "schedule": "*/30 * * * *"
    }
  ]
}
